{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python@latest",
      "config": {
        "pythonVersion": "3.9"
      }
    },
    {
      "src": "index.html",
      "use": "@vercel/static@latest"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/",
      "dest": "index.html"
    }
  ]
}
